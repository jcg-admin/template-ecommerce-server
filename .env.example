# =============================================================================
# .env.example -- template-ecomerce-ui-server
# =============================================================================
# Copia este archivo a .env y completa los valores antes de ejecutar
# cualquier script del repositorio.
#
#   cp .env.example .env
#
# El archivo .env esta en .gitignore -- nunca lo subas al repositorio.
#
# Las variables las consume tanto los provisioners (provisioners/*.sh)
# como los scripts de operacion (scripts/verify.sh, renew_ssl.sh) via
# `source .env` al inicio de cada script.
#
# Layout asumido (D-CUENTAS + D-STORAGE):
#
#   Cuentas Linux (UIDs canonicos del procedimiento externo):
#     deploy        UID 1000  (sudo admin, ejecuta provisioners)
#     infra         UID 1001  (sudo granular NOPASSWD)
#     develop       UID 1002  (owner del codigo UI, sin sudo)
#     svc-backups   UID  999  (owner Clase B backups, nologin)
#
#   Storage:
#     Clase A: /srv/repos/ecom/template-e-comerce-ui  (codigo UI)
#     Clase B: /srv/backups/project                   (backups)
#
# Nginx corre como www-data (default Ubuntu) tras drop-privileges del
# master root. Los repos tienen perms 755/644 develop:develop, asi
# "other" (www-data) puede leer codigo + dist. La key.pem SSL queda
# 0600 root:root y Nginx master root la lee antes de fork-ear workers.
# =============================================================================


# -----------------------------------------------------------------------------
# Dominio publico
# -----------------------------------------------------------------------------
# El nombre de dominio que Nginx usara como server_name.
# Debe ser un dominio publico resolvible para que Let's Encrypt funcione.
# Para desarrollo local puede ser "localhost" (usara self-signed
# automaticamente via openssl).
DOMAIN=midominio.com


# -----------------------------------------------------------------------------
# UI (Static bundle servido por Nginx)
# -----------------------------------------------------------------------------
# Path absoluto al build de produccion del UI. Output de
# `npm run build` ejecutado en el repo template-e-comerce-ui.
# Nginx sirve estos archivos directamente desde filesystem (sin pasar
# por ningun backend).
#
# Para que Nginx (workers www-data) pueda leerlo:
#   - El directorio padre debe tener mode 0755.
#   - Los archivos deben tener mode 0644.
#   - Owner: develop:develop.
#
# Valor canonico segun el procedimiento externo de almacenamiento
# (Clase A):
UI_DIST=/srv/repos/ecom/template-e-comerce-ui/dist


# -----------------------------------------------------------------------------
# API upstream (Reverse proxy /api/*)
# -----------------------------------------------------------------------------
# URL del backend al que Nginx reverse-proxy-eara las peticiones a
# /api/*.  Si esta VACIO, Nginx devuelve 502 Bad Gateway para /api/*
# hasta que se configure (escenario valido si solo se sirve UI estatico
# durante una fase del proyecto).
#
# Este server es BACKEND-AGNOSTIC (decision D-BACKEND-AGNOSTIC):
# no asume tecnologia del backend. Ejemplos validos:
#
#   API_UPSTREAM=http://127.0.0.1:8000        # Django runserver dev
#   API_UPSTREAM=http://127.0.0.1:3000        # Node/Express dev
#   API_UPSTREAM=unix:/run/gunicorn.sock      # Django produccion
#   API_UPSTREAM=http://api-internal:80       # Microservicio (Docker)
#   API_UPSTREAM=https://api.midominio.com    # Backend en otro host
#
# Si se usa socket Unix, el usuario www-data necesita permiso de lectura
# en el socket. Si se usa http remoto, abrir el puerto saliente en UFW
# (allow outgoing ya lo permite por defecto).
API_UPSTREAM=


# -----------------------------------------------------------------------------
# SSL / Let's Encrypt
# -----------------------------------------------------------------------------
# Email para notificaciones de Let's Encrypt (expiracion, problemas).
SSL_EMAIL=admin@midominio.com

# Directorio donde acme.sh instala los certificados.
# provisioners/ssl/setup_ssl.sh crea este directorio con mode 0755:
#   cert.pem + fullchain.pem 0644 (publicos, world-readable)
#   key.pem 0600 root:root (Nginx master lo lee como root)
SSL_CERT_DIR=/etc/ssl/midominio.com

# Umbrales de alerta de expiracion del certificado (dias).
# scripts/verify.sh emite WARN si quedan menos de SSL_CERT_DAYS_WARN dias.
# scripts/verify.sh emite ERR  si quedan menos de SSL_CERT_DAYS_ERR dias.
# scripts/renew_ssl.sh usa SSL_CERT_DAYS_WARN como umbral de renovacion.
SSL_CERT_DAYS_WARN=30
SSL_CERT_DAYS_ERR=7

# Modo staging de Let's Encrypt (opcional, solo para tests).
# Cuando esta a "true", setup_ssl.sh usa el endpoint staging de Let's
# Encrypt que no consume rate-limit pero produce certs no validos en
# browser. Util para validar el flujo ACME sin gastar el rate-limit
# de produccion (5 certs por dominio cada 168h).
SSL_STAGING=false


# -----------------------------------------------------------------------------
# Nginx workers
# -----------------------------------------------------------------------------
# Procesos worker que sirven peticiones. Default "auto" = un worker por
# nucleo de CPU (Nginx lo detecta automaticamente). Override numerico
# si quieres forzar un valor:
#   NGINX_WORKER_PROCESSES=1   # VPS pequenio
#   NGINX_WORKER_PROCESSES=4   # 4 vCPUs
NGINX_WORKER_PROCESSES=auto

# Conexiones concurrentes por worker. Default 1024. Capacidad total
# del server = NGINX_WORKER_PROCESSES * NGINX_WORKER_CONNECTIONS.
# Para incrementar, comprobar antes ulimit -n (open files limit).
NGINX_WORKER_CONNECTIONS=1024


# -----------------------------------------------------------------------------
# SSH
# -----------------------------------------------------------------------------
# Puerto SSH del servidor. Usar un puerto no estandar (distinto de 22)
# es buena practica en servidores expuestos a Internet -- elimina el
# ruido de bots automaticos que escanean el puerto 22 de toda la red.
#
# IMPORTANTE: el mismo valor debe usarse en:
#   provisioners/firewall/setup_firewall.sh
#   provisioners/security/setup_ssh_hardening.sh
# Cambiar el puerto despues del setup requiere:
#   1. Actualizar SSH_PORT en .env
#   2. sudo bash provisioners/firewall/setup_firewall.sh
#   3. sudo bash provisioners/security/setup_ssh_hardening.sh
#   4. Reconectar en el nuevo puerto antes de cerrar la sesion actual
#
# NOTA WSL2: en WSL2 sshd lo provee Windows (no Linux). Los scripts
# setup_firewall.sh y setup_ssh_hardening.sh detectan ausencia de
# UFW/sshd via is_wsl2() y hacen skip explicito -- by design, no bug.
SSH_PORT=2222


# -----------------------------------------------------------------------------
# fail2ban
# -----------------------------------------------------------------------------
# Parametros de las jails configuradas por
# provisioners/security/setup_fail2ban.sh.
#
# Jail sshd -- intentos fallidos de autenticacion SSH
F2B_SSH_MAXRETRY=5
F2B_SSH_FINDTIME=600
F2B_SSH_BANTIME=3600

# Jail nginx-limit-req -- 503 por rate-limit de Nginx (cuando un
# cliente sobrepasa el limit_req configurado en el vhost)
F2B_NGINX_LIMIT_REQ_MAXRETRY=10
F2B_NGINX_LIMIT_REQ_FINDTIME=600
F2B_NGINX_LIMIT_REQ_BANTIME=1800

# Jail nginx-botsearch -- patrones de scanner conocidos
# (e.g. /wp-admin, /phpmyadmin, /xmlrpc.php en un server sin
# WordPress/PHP)
F2B_NGINX_BOTSEARCH_MAXRETRY=2
F2B_NGINX_BOTSEARCH_FINDTIME=600
F2B_NGINX_BOTSEARCH_BANTIME=86400


# -----------------------------------------------------------------------------
# Logs (opcional)
# -----------------------------------------------------------------------------
# Directorio donde utils/logging.sh init_log escribira logs estructurados
# de los provisioners (lineas con timestamp). Si el directorio no existe,
# init_log lo crea. Default: <repo-root>/logs/
#
# Esta variable se exporta como PROJECT_ROOT al ejecutar los scripts
# desde la raiz del repo; init_log la consume.
# PROJECT_ROOT=/srv/repos/ecom/template-ecomerce-ui-server
